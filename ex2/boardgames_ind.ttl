:jogo_puerto_rico a :Jogo,
        owl:NamedIndividual ;
    :categoria "Strategy" ;
    :descricao "Ship goods, construct buildings, and choose roles to become the most prosperous in Puerto Rico." ;
    :id "puerto-rico" ;
    :maxJogadores 5 ;
    :minJogadores 3 ;
    :nome "Puerto Rico" ;
    :tempoJogo 150 .

